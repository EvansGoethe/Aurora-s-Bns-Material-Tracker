<Window x:Class="BnsMaterialTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="洛洛劍靈材料追蹤器" Height="680" Width="1100"
        MinHeight="560" MinWidth="860"
        Background="{StaticResource BgApp}"
        Icon="pack://application:,,,/ABnS_.png"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Sidebar ──────────────────────────────────────── -->
    <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
      <DockPanel>

        <!-- Logo -->
        <Border DockPanel.Dock="Top" Padding="16,20,16,12">
          <StackPanel>
            <TextBlock x:Name="TxtGameTitle" Text="洛洛劍靈"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBlue}"/>
            <TextBlock x:Name="TxtAppTitle" Text="材料追蹤器"
                       FontSize="12" Foreground="{StaticResource TextSecondary}"/>
            <TextBlock x:Name="TxtServer" Text="台服"
                       FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>

        <Separator DockPanel.Dock="Top"/>

        <!-- Open folder button at bottom -->
        <Button x:Name="BtnOpenFolder" DockPanel.Dock="Bottom"
                Style="{StaticResource BtnGhost}"
                Margin="8,8" Click="BtnOpenFolder_Click">
          <TextBlock x:Name="TxtOpenFolder" Text="📂 開啟資料夾"
                     Foreground="{StaticResource TextMuted}" FontSize="12"/>
        </Button>

        <!-- Nav items -->
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="8,4">

            <TextBlock x:Name="TxtNavMain" Text="主要功能"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       Margin="12,8,0,4"/>

            <RadioButton x:Name="NavDashboard"   Style="{StaticResource NavBtn}"
                         IsChecked="True"  Checked="Nav_Checked" Tag="dashboard">
              <TextBlock Text="📊 總覽"/>
            </RadioButton>
            <RadioButton x:Name="NavTracker"     Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="tracker">
              <TextBlock Text="⚔️ 副本追蹤"/>
            </RadioButton>
            <RadioButton x:Name="NavCalculator"  Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="calculator">
              <TextBlock Text="🧮 材料計算"/>
            </RadioButton>
            <RadioButton x:Name="NavPredictor"   Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="predictor">
              <TextBlock Text="🎯 達成預測"/>
            </RadioButton>
            <RadioButton x:Name="NavInventory"   Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="inventory">
              <TextBlock Text="📦 倉庫"/>
            </RadioButton>
            <RadioButton x:Name="NavBagScan"     Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="bagscan">
              <TextBlock Text="🔍 截圖辨識"/>
            </RadioButton>
            <RadioButton x:Name="NavMarket"      Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="market">
              <TextBlock Text="💰 效益分析"/>
            </RadioButton>

            <TextBlock x:Name="TxtNavAdmin" Text="管理"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       Margin="12,12,0,4"/>

            <RadioButton x:Name="NavDataEditor"  Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="dataeditor">
              <TextBlock Text="✏️ 資料編輯"/>
            </RadioButton>
            <RadioButton x:Name="NavSettings"    Style="{StaticResource NavBtn}"
                         Checked="Nav_Checked" Tag="settings">
              <TextBlock Text="⚙️ 設定"/>
            </RadioButton>

          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ── Content area ─────────────────────────────────── -->
    <ContentControl x:Name="MainContent" Grid.Column="1"/>

  </Grid>
</Window>
