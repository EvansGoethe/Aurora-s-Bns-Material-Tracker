<UserControl x:Class="BnsMaterialTracker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Background="{StaticResource BgApp}" Padding="20">
    <StackPanel>

      <!-- Title -->
      <TextBlock x:Name="TxtTitle" Text="總覽儀表板"
                 FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

      <!-- Stats row -->
      <UniformGrid x:Name="StatsGrid" Rows="1" Columns="4" Margin="0,0,0,16">

        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="⏱" FontSize="22" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatTime" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBlue}"/>
            <TextBlock x:Name="StatTimeLabel" Text="今日預估剩餘時間"
                       Foreground="{StaticResource TextSecondary}" FontSize="11"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Margin="4,0">
          <StackPanel>
            <TextBlock Text="⚔️" FontSize="22" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatDaily" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentGreen}"/>
            <TextBlock x:Name="StatDailyLabel" Text="今日副本進度"
                       Foreground="{StaticResource TextSecondary}" FontSize="11"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Margin="4,0">
          <StackPanel>
            <TextBlock Text="📅" FontSize="22" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatWeekly" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentPurple}"/>
            <TextBlock x:Name="StatWeeklyLabel" Text="本週副本進度"
                       Foreground="{StaticResource TextSecondary}" FontSize="11"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Margin="8,0,0,0">
          <StackPanel>
            <TextBlock Text="💰" FontSize="22" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatGold" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentYellow}"/>
            <TextBlock x:Name="StatGoldLabel" Text="金幣"
                       Foreground="{StaticResource TextSecondary}" FontSize="11"/>
          </StackPanel>
        </Border>

      </UniformGrid>

      <!-- Two columns: daily + weekly -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Daily dungeons -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock x:Name="TxtDailyTitle" Text="今日副本"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <ItemsControl x:Name="DailyList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                      <ProgressBar Value="{Binding Pct, Mode=OneWay}" Maximum="100"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="TxtDailyEmpty" Text="尚未設定副本"
                       Foreground="{StaticResource TextMuted}"
                       Visibility="Collapsed" FontSize="12"/>
          </StackPanel>
        </Border>

        <!-- Weekly dungeons -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock x:Name="TxtWeeklyTitle" Text="本週副本"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <ItemsControl x:Name="WeeklyList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                      <ProgressBar Value="{Binding Pct, Mode=OneWay}" Maximum="100"
                                   Foreground="{StaticResource AccentPurple}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="TxtWeeklyEmpty" Text="尚未設定副本"
                       Foreground="{StaticResource TextMuted}"
                       Visibility="Collapsed" FontSize="12"/>
          </StackPanel>
        </Border>

      </Grid>

      <!-- Goals summary -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock x:Name="TxtGoalsTitle" Text="升級目標"
                     FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <ItemsControl x:Name="GoalsList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,3">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"/>
                  <TextBlock Grid.Column="1" Text="{Binding Steps}"
                             Foreground="{StaticResource TextSecondary}" Margin="16,0"/>
                  <TextBlock Grid.Column="2" Text="{Binding Eta}"
                             Foreground="{StaticResource AccentGreen}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock x:Name="TxtGoalsEmpty" Text="尚未設定升級目標"
                     Foreground="{StaticResource TextMuted}"
                     Visibility="Collapsed" FontSize="12"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
