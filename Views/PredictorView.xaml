<UserControl x:Class="BnsMaterialTracker.Views.PredictorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Background="{StaticResource BgApp}" Padding="20">
    <StackPanel>

      <TextBlock x:Name="TxtTitle" Text="目標達成預測"
                 FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock x:Name="TxtPlayTimeInfo" FontSize="12"
                 Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

      <!-- No goals hint -->
      <Border x:Name="CardEmpty" Style="{StaticResource Card}">
        <StackPanel HorizontalAlignment="Center" Margin="0,20">
          <TextBlock x:Name="TxtNoGoals" Text="尚未設定升級目標"
                     FontSize="15" HorizontalAlignment="Center"
                     Foreground="{StaticResource TextMuted}"/>
          <TextBlock x:Name="TxtNoGoalsHint" FontSize="12"
                     Foreground="{StaticResource TextMuted}"
                     HorizontalAlignment="Center" Margin="0,6"/>
        </StackPanel>
      </Border>

      <!-- Goals list -->
      <ItemsControl x:Name="GoalsList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource Card}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="{Binding StepsLabel}"
                               Foreground="{StaticResource TextMuted}" FontSize="12"/>
                  </Grid>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding DaysLabel}" FontSize="22" FontWeight="Bold"
                                 Foreground="{Binding DaysColor}"/>
                      <TextBlock Text="{Binding DaysDesc}"
                                 Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding DateLabel}" FontSize="16" FontWeight="SemiBold"
                                 Foreground="{StaticResource AccentBlue}"/>
                      <TextBlock Text="{Binding DateDesc}"
                                 Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                      <TextBlock Text="{Binding Bottleneck}" FontSize="12"
                                 Foreground="{StaticResource AccentYellow}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Grid>

                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource BtnDanger}"
                        Tag="{Binding GoalId}" Click="BtnRemoveGoal_Click"
                        VerticalAlignment="Top" Margin="12,0,0,0" Padding="8,4">
                  <TextBlock x:Name="TxtDelete" Text="✕"/>
                </Button>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
