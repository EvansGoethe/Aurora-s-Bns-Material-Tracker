<UserControl x:Class="BnsMaterialTracker.Views.MarketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Background="{StaticResource BgApp}" Padding="20">
    <StackPanel>

      <TextBlock x:Name="TxtTitle" Text="效益分析"
                 FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock x:Name="TxtSubtitle"
                 Foreground="{StaticResource TextSecondary}"
                 FontSize="12" Margin="0,0,0,20"/>

      <!-- Material price inputs -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock x:Name="TxtPriceLabel" Text="💲 材料市場單價"
                     FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <ItemsControl x:Name="PriceList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                  <TextBox   Grid.Column="2" Text="{Binding Price, Mode=TwoWay, StringFormat=F2}"
                             Tag="{Binding Id}" Height="32" TextChanged="Price_Changed"/>
                  <TextBlock Grid.Column="3" Text=" 金" Foreground="{StaticResource AccentYellow}"
                             VerticalAlignment="Center"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Dungeon efficiency table -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock x:Name="TxtEffLabel" Text="⚔️ 副本效益排名"
                     FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <TextBlock x:Name="TxtNoData" Text="請先設定副本掉落資料"
                     Foreground="{StaticResource TextMuted}"
                     Visibility="Collapsed"/>
          <ItemsControl x:Name="DungeonEffList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource BgInput}" CornerRadius="10"
                        Padding="12,10" Margin="0,0,0,6">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="28" Height="28"
                            Background="{Binding RankBg}" CornerRadius="14"
                            Margin="0,0,10,0">
                      <TextBlock Text="{Binding Rank}" FontWeight="Bold" FontSize="12"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Foreground="White"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding TypeLabel}"
                                 Foreground="{StaticResource TextMuted}" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="16,0" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding GoldPerMin}"
                                 Foreground="{StaticResource AccentYellow}"
                                 FontWeight="Bold" TextAlignment="Right"/>
                      <TextBlock Text="金/分" Foreground="{StaticResource TextMuted}"
                                 FontSize="10" TextAlignment="Right"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="16,0" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding TimePerUnit}"
                                 Foreground="{StaticResource TextSecondary}"
                                 TextAlignment="Right"/>
                      <TextBlock Text="分/個" Foreground="{StaticResource TextMuted}"
                                 FontSize="10" TextAlignment="Right"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="16,0,0,0" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding AvgPerRun}"
                                 Foreground="{StaticResource TextSecondary}"
                                 TextAlignment="Right"/>
                      <TextBlock Text="均/次" Foreground="{StaticResource TextMuted}"
                                 FontSize="10" TextAlignment="Right"/>
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
