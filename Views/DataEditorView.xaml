<UserControl x:Class="BnsMaterialTracker.Views.DataEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Resources>
    <!-- Field label style -->
    <Style x:Key="FieldLbl" TargetType="TextBlock">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>
    <!-- Small icon delete button -->
    <Style x:Key="BtnDel" TargetType="Button" BasedOn="{StaticResource BtnDanger}">
      <Setter Property="Width" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <!-- Separator line -->
    <Style x:Key="Sep" TargetType="Border">
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="BorderBrush" Value="{StaticResource BgInput}"/>
      <Setter Property="Margin" Value="0,8,0,8"/>
    </Style>
  </UserControl.Resources>

  <Grid Background="{StaticResource BgApp}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="Auto"/>  <!-- Tabs -->
      <RowDefinition Height="*"/>     <!-- Content -->
    </Grid.RowDefinitions>

    <!-- ── Header ── -->
    <Border Grid.Row="0" Padding="20,16,20,0">
      <StackPanel>
        <TextBlock x:Name="TxtTitle" Text="資料編輯"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock x:Name="TxtSubtitle"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
      </StackPanel>
    </Border>

    <!-- ── Tab bar ── -->
    <Border Grid.Row="1" Padding="20,12,20,0">
      <StackPanel Orientation="Horizontal">
        <RadioButton x:Name="TabDungeons" Style="{StaticResource NavBtn}"
                     GroupName="EditorTab" IsChecked="True"
                     Checked="Tab_Checked" Tag="dungeons">
          <TextBlock x:Name="TxtTabDungeons" Text="副本"/>
        </RadioButton>
        <RadioButton x:Name="TabMaterials" Style="{StaticResource NavBtn}"
                     GroupName="EditorTab"
                     Checked="Tab_Checked" Tag="materials">
          <TextBlock x:Name="TxtTabMaterials" Text="材料"/>
        </RadioButton>
        <RadioButton x:Name="TabUpgrades" Style="{StaticResource NavBtn}"
                     GroupName="EditorTab"
                     Checked="Tab_Checked" Tag="upgrades">
          <TextBlock x:Name="TxtTabUpgrades" Text="升級路線"/>
        </RadioButton>
      </StackPanel>
    </Border>

    <!-- ── Content area ── -->
    <Grid Grid.Row="2" Margin="20,10,20,20">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ════════════════════════════════════════════════
           PANEL: 副本 (Dungeons)
           ════════════════════════════════════════════════ -->
      <ScrollViewer x:Name="PanelDungeons" Grid.Row="0"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding DungeonList}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                  <StackPanel>

                    <!-- Row 1: Name / ShortName / Delete -->
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="副本名稱"/>
                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="簡稱"/>
                        <TextBox Text="{Binding ShortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                      </StackPanel>
                      <Button Grid.Column="4" Style="{StaticResource BtnDel}"
                              Tag="{Binding}" Click="DeleteDungeon_Click"
                              VerticalAlignment="Bottom">🗑</Button>
                    </Grid>

                    <!-- Row 2: ID / Type / EstimatedMinutes -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <StackPanel Margin="0,0,8,0" MinWidth="160">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="ID"/>
                        <TextBox Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                      </StackPanel>
                      <StackPanel Margin="0,0,8,0" Width="100">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="重置週期"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding DungeonTypeOptions,
                                    RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding Type, Mode=TwoWay}"/>
                      </StackPanel>
                      <StackPanel Width="80">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="預估分鐘"/>
                        <TextBox Text="{Binding EstimatedMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                      </StackPanel>
                    </StackPanel>

                    <!-- Row 3: Mode / Difficulty / Limits -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <StackPanel Margin="0,0,8,0" Width="100">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="分類"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding ModeOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding Mode, Mode=TwoWay}"/>
                      </StackPanel>
                      <StackPanel Margin="0,0,8,0" Width="110">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="難度"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding DifficultyOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding Difficulty, Mode=TwoWay}"/>
                      </StackPanel>
                      <StackPanel Margin="0,0,8,0" Width="90">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="每日上限"/>
                        <TextBox Text="{Binding DailyLimit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                      </StackPanel>
                      <StackPanel Width="90">
                        <TextBlock Style="{StaticResource FieldLbl}" Text="每週上限"/>
                        <TextBox Text="{Binding WeeklyLimit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                      </StackPanel>
                    </StackPanel>

                    <!-- Drops sub-list -->
                    <Border Style="{StaticResource Sep}"/>
                    <TextBlock Text="掉落設定" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>

                    <ItemsControl ItemsSource="{Binding Drops}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="8"/>
                              <ColumnDefinition Width="72"/>
                              <ColumnDefinition Width="8"/>
                              <ColumnDefinition Width="64"/>
                              <ColumnDefinition Width="8"/>
                              <ColumnDefinition Width="64"/>
                              <ColumnDefinition Width="8"/>
                              <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Style="{StaticResource FieldLbl}" Text="材料"/>
                              <ComboBox Height="36"
                                        ItemsSource="{Binding MaterialList,
                                          RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        SelectedValuePath="Id"
                                        SelectedValue="{Binding MaterialId, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                      <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="15"
                                                 VerticalAlignment="Center"/>
                                      <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                              <TextBlock Style="{StaticResource FieldLbl}" Text="機率"/>
                              <TextBox Text="{Binding Chance, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                              <TextBlock Style="{StaticResource FieldLbl}" Text="最少"/>
                              <TextBox Text="{Binding Min, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                              <TextBlock Style="{StaticResource FieldLbl}" Text="最多"/>
                              <TextBox Text="{Binding Max, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                            </StackPanel>
                            <Button Grid.Column="8" Style="{StaticResource BtnDel}"
                                    Tag="{Binding}" Click="DeleteDrop_Click"
                                    VerticalAlignment="Bottom">🗑</Button>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Style="{StaticResource BtnGhost}" Margin="0,6,0,0"
                            HorizontalAlignment="Left" Tag="{Binding}" Click="AddDrop_Click">
                      ＋ 掉落
                    </Button>

                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Add dungeon buttons -->
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
            <Button Style="{StaticResource BtnGhost}" Margin="0,0,8,0"
                    Click="AddDungeon_Click">
              ＋ 新增副本
            </Button>
            <Button Style="{StaticResource BtnGhost}"
                    Click="BtnFromScreenshot_Click">
              📷 從截圖匯入
            </Button>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- ════════════════════════════════════════════════
           PANEL: 材料 (Materials)
           ════════════════════════════════════════════════ -->
      <ScrollViewer x:Name="PanelMaterials" Grid.Row="0"
                    Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <Border Style="{StaticResource Card}" Padding="0">
            <StackPanel>
              <!-- Column headers -->
              <Grid Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="64"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="150"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="140"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLbl}" Text="圖示"/>
                <TextBlock Grid.Column="2" Style="{StaticResource FieldLbl}" Text="ID"/>
                <TextBlock Grid.Column="4" Style="{StaticResource FieldLbl}" Text="名稱"/>
                <TextBlock Grid.Column="6" Style="{StaticResource FieldLbl}" Text="分類"/>
              </Grid>
              <Border Style="{StaticResource Sep}" Margin="0,0,0,4"/>

              <ItemsControl ItemsSource="{Binding MaterialList}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="16,0,16,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <ComboBox Grid.Column="0" Height="36" FontSize="18"
                                ItemsSource="{Binding IconChoices,
                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                SelectedItem="{Binding Icon, Mode=TwoWay}">
                        <ComboBox.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Width="216" Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="18"
                                       Width="30" Height="30"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <TextBox Grid.Column="2"
                               Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                      <TextBox Grid.Column="4"
                               Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                      <ComboBox Grid.Column="6" Height="36"
                                ItemsSource="{Binding CategoryOptions,
                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                DisplayMemberPath="Label"
                                SelectedValuePath="Key"
                                SelectedValue="{Binding Category, Mode=TwoWay}"/>
                      <Button Grid.Column="8" Style="{StaticResource BtnDel}"
                              Tag="{Binding}" Click="DeleteMaterial_Click">🗑</Button>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Button Style="{StaticResource BtnGhost}" Margin="16,8,16,12"
                      HorizontalAlignment="Left" Click="AddMaterial_Click">
                ＋ 新增材料
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- ════════════════════════════════════════════════
           PANEL: 升級路線 (Upgrades)
           ════════════════════════════════════════════════ -->
      <Grid x:Name="PanelUpgrades" Grid.Row="0" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- Category filter bar -->
          <RowDefinition Height="*"/>     <!-- Steps list -->
        </Grid.RowDefinitions>

        <!-- Category filter -->
        <Border Grid.Row="0" Margin="0,0,0,10">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="分類：" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding UpgradeCategoryOptions}"
                      DisplayMemberPath="Label"
                      SelectedItem="{Binding SelectedUpgradeCat, Mode=TwoWay}"
                      Width="160" Height="36"/>
          </StackPanel>
        </Border>

        <!-- Steps list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding FilteredUpgrades}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>

                      <!-- Row 1: Name + ID + Delete -->
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="8"/>
                          <ColumnDefinition Width="150"/>
                          <ColumnDefinition Width="8"/>
                          <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                          <TextBlock Style="{StaticResource FieldLbl}" Text="步驟名稱"/>
                          <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                          <TextBlock Style="{StaticResource FieldLbl}" Text="ID"/>
                          <TextBox Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="4" Style="{StaticResource BtnDel}"
                                Tag="{Binding}" Click="DeleteUpgradeStep_Click"
                                VerticalAlignment="Bottom">🗑</Button>
                      </Grid>

                      <!-- Row 2: FromStage / ToStage / GoldCost -->
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,8,0" Width="90">
                          <TextBlock Style="{StaticResource FieldLbl}" Text="起始階段"/>
                          <TextBox Text="{Binding FromStage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0" Width="90">
                          <TextBlock Style="{StaticResource FieldLbl}" Text="目標階段"/>
                          <TextBox Text="{Binding ToStage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel Width="90">
                          <TextBlock Style="{StaticResource FieldLbl}" Text="金幣費用"/>
                          <TextBox Text="{Binding GoldCost, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                      </StackPanel>

                      <!-- Requirements sub-list -->
                      <Border Style="{StaticResource Sep}"/>
                      <TextBlock Text="材料需求" FontSize="12" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>

                      <ItemsControl ItemsSource="{Binding Requirements}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="0,0,0,4">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="32"/>
                              </Grid.ColumnDefinitions>
                              <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLbl}" Text="材料"/>
                                <ComboBox Height="36"
                                          ItemsSource="{Binding MaterialList,
                                            RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding MaterialId, Mode=TwoWay}">
                                  <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                      <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="15"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                      </StackPanel>
                                    </DataTemplate>
                                  </ComboBox.ItemTemplate>
                                </ComboBox>
                              </StackPanel>
                              <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLbl}" Text="數量"/>
                                <TextBox Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                              </StackPanel>
                              <Button Grid.Column="4" Style="{StaticResource BtnDel}"
                                      Tag="{Binding}" Click="DeleteReq_Click"
                                      VerticalAlignment="Bottom">🗑</Button>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <Button Style="{StaticResource BtnGhost}" Margin="0,6,0,0"
                              HorizontalAlignment="Left" Tag="{Binding}" Click="AddReq_Click">
                        ＋ 需求材料
                      </Button>

                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Style="{StaticResource BtnGhost}" Margin="0,4,0,4"
                    HorizontalAlignment="Left" Click="AddUpgradeStep_Click">
              ＋ 新增步驟
            </Button>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- ── Bottom bar: status / reload / save ── -->
      <Grid Grid.Row="1" Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="TxtStatus" Grid.Column="0"
                   Foreground="{StaticResource TextMuted}"
                   VerticalAlignment="Center" FontSize="12"
                   TextTrimming="CharacterEllipsis"/>

        <Button x:Name="BtnReload" Grid.Column="1"
                Style="{StaticResource BtnGhost}" Click="BtnReload_Click">
          <TextBlock>↺ 重新載入</TextBlock>
        </Button>

        <Button x:Name="BtnSave" Grid.Column="3"
                Style="{StaticResource BtnPrimary}" Click="BtnSave_Click">
          <TextBlock>💾 儲存全部</TextBlock>
        </Button>

      </Grid>
    </Grid>

    <!-- ══ Dungeon import overlay ════════════════════════════════════ -->
    <Grid x:Name="DungImportOverlay" Grid.RowSpan="3"
          Background="#CC000000" Panel.ZIndex="30" Visibility="Collapsed">
      <Border Background="{StaticResource BgCard}"
              BorderBrush="{StaticResource BorderColor}"
              BorderThickness="1" CornerRadius="8"
              Width="520" Margin="20"
              VerticalAlignment="Stretch" HorizontalAlignment="Center">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

          <TextBlock Text="從截圖匯入副本"
                     FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

          <!-- Import / Paste buttons -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnDungImport" Content="📂 選擇截圖"
                    Style="{StaticResource BtnGhost}" Height="36" MinWidth="120"
                    Margin="0,0,8,0" Click="BtnDungImport_Click"/>
            <Button x:Name="BtnDungPaste" Content="📋 貼上截圖"
                    Style="{StaticResource BtnGhost}" Height="36" MinWidth="120"
                    Click="BtnDungPaste_Click"/>
          </StackPanel>

          <!-- Status text -->
          <TextBlock x:Name="TxtDungStatus" Text="請選擇或貼上副本資訊頁的截圖"
                     FontSize="12" Foreground="{StaticResource TextMuted}"
                     Margin="0,0,0,4" TextWrapping="Wrap"/>

          <!-- Result panel (shown after successful OCR) -->
          <StackPanel x:Name="DungResultPanel" Visibility="Collapsed" Margin="0,8,0,0">

            <Border BorderBrush="{StaticResource BgInput}"
                    BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

            <!-- Dungeon name (editable) -->
            <TextBlock Text="副本名稱（OCR 辨識結果，請確認是否正確）" FontSize="11"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtDungName" Height="40" FontSize="13" Margin="0,0,0,12"/>

            <!-- Entries preview -->
            <TextBlock Text="將新增以下條目：" FontSize="11"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
            <ItemsControl x:Name="DungEntryList" Margin="0,0,0,8">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontSize="12"
                             Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Quick material creation ── -->
            <Border BorderBrush="{StaticResource BgInput}"
                    BorderThickness="0,0,0,1" Margin="0,4,0,10"/>

            <TextBlock Text="📝 快速建立新材料" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

            <!-- Auto-detected tokens from OCR words -->
            <TextBlock Text="OCR 偵測到的詞彙（點擊填入名稱欄）："
                       FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
            <ItemsControl x:Name="DetectedTokenList" Margin="0,0,0,8">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Content="{Binding}" Margin="0,0,4,4"
                          Style="{StaticResource BtnGhost}" FontSize="11" Height="26"
                          Click="BtnDetectedToken_Click"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="或手動輸入名稱按 ＋ 新增（即時計入上方匹配數）："
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap" Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="40"/>
              </Grid.ColumnDefinitions>
              <TextBox x:Name="TxtNewMatName" Grid.Column="0" Height="40" FontSize="12"
                       VerticalContentAlignment="Center"
                       KeyDown="TxtNewMatName_KeyDown"/>
              <Button x:Name="BtnAddNewMat" Grid.Column="2" Content="＋"
                      Style="{StaticResource BtnPrimary}" Height="40" Width="40"
                      Click="BtnAddNewMat_Click"/>
            </Grid>

            <ItemsControl x:Name="PendingMatList" Margin="0,0,0,4">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="4"/>
                      <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                               FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource AccentColor}"/>
                    <Button Grid.Column="2" Content="✕" Width="32" Height="32"
                            FontSize="14" Style="{StaticResource BtnGhost}"
                            Foreground="{StaticResource AccentRed}"
                            Tag="{Binding}" Click="BtnRemovePendingMat_Click"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Raw OCR text (debug, collapsible) -->
            <Expander x:Name="ExpanderOcr" Header="OCR 原始文字（debug）"
                      FontSize="11" Foreground="{StaticResource TextMuted}"
                      Margin="0,8,0,0" Visibility="Collapsed">
              <TextBox x:Name="TxtOcrRaw" IsReadOnly="True" TextWrapping="Wrap"
                       MaxHeight="120" FontSize="10" Margin="0,4,0,0"
                       VerticalScrollBarVisibility="Auto"
                       Background="{StaticResource BgApp}"
                       Foreground="{StaticResource TextMuted}"/>
            </Expander>
          </StackPanel>

          <!-- Confirm / Cancel -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,4">
            <Button x:Name="BtnDungCancel" Content="取消" Width="80" Height="34"
                    Style="{StaticResource BtnGhost}" Margin="0,0,8,0"
                    Click="BtnDungCancel_Click"/>
            <Button x:Name="BtnDungConfirm" Content="確認匯入" Width="100" Height="34"
                    Style="{StaticResource BtnPrimary}" IsEnabled="False"
                    Click="BtnDungConfirm_Click"/>
          </StackPanel>

        </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

