<UserControl x:Class="BnsMaterialTracker.Views.DailyTrackerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Background="{StaticResource BgApp}" Padding="20">
    <StackPanel>

      <!-- Title + reset buttons -->
      <Grid Margin="0,0,0,20">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Column="0"
                   Text="副本進度追蹤" FontSize="22" FontWeight="Bold"/>
        <Button x:Name="BtnResetDaily" Grid.Column="1"
                Style="{StaticResource BtnGhost}" Click="BtnResetDaily_Click">
          <TextBlock x:Name="TxtResetDaily" Text="↺ 重置今日"/>
        </Button>
        <Button x:Name="BtnResetWeekly" Grid.Column="3"
                Style="{StaticResource BtnGhost}" Click="BtnResetWeekly_Click">
          <TextBlock x:Name="TxtResetWeekly" Text="↺ 重置本週"/>
        </Button>
      </Grid>

      <!-- Daily section -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock x:Name="TxtDailyHeader" Text="每日副本"
                     FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <ItemsControl x:Name="DailyList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource BgInput}" CornerRadius="10"
                        Padding="12,10" Margin="0,0,0,8">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding EstLabel}"
                                   Foreground="{StaticResource TextMuted}" FontSize="11"/>
                      </Grid>
                      <ProgressBar Value="{Binding Pct, Mode=OneWay}" Maximum="100" Margin="0,6,0,0"
                                   Foreground="{Binding BarColor}"/>
                      <TextBlock Text="{Binding SubLabel}"
                                 Foreground="{StaticResource TextMuted}" FontSize="11"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                      <Button Tag="{Binding}" Click="BtnMinus_Click"
                              Style="{StaticResource BtnGhost}" Padding="8,4">
                        <TextBlock Text="－" FontSize="16" FontWeight="Bold"/>
                      </Button>
                      <TextBlock Text="{Binding CountLabel}"
                                 FontSize="16" FontWeight="Bold" Margin="8,0"
                                 VerticalAlignment="Center" MinWidth="50"
                                 TextAlignment="Center"/>
                      <Button Tag="{Binding}" Click="BtnPlus_Click"
                              Style="{StaticResource BtnPrimary}" Padding="8,4">
                        <TextBlock Text="＋" FontSize="16" FontWeight="Bold"/>
                      </Button>
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock x:Name="TxtDailyEmpty"
                     Foreground="{StaticResource TextMuted}" FontSize="12"
                     Visibility="Collapsed"/>
        </StackPanel>
      </Border>

      <!-- Weekly section -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock x:Name="TxtWeeklyHeader" Text="每週副本"
                     FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <ItemsControl x:Name="WeeklyList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource BgInput}" CornerRadius="10"
                        Padding="12,10" Margin="0,0,0,8">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding EstLabel}"
                                   Foreground="{StaticResource TextMuted}" FontSize="11"/>
                      </Grid>
                      <ProgressBar Value="{Binding Pct, Mode=OneWay}" Maximum="100" Margin="0,6,0,0"
                                   Foreground="{StaticResource AccentPurple}"/>
                      <TextBlock Text="{Binding SubLabel}"
                                 Foreground="{StaticResource TextMuted}" FontSize="11"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                      <Button Tag="{Binding}" Click="BtnMinusW_Click"
                              Style="{StaticResource BtnGhost}" Padding="8,4">
                        <TextBlock Text="－" FontSize="16" FontWeight="Bold"/>
                      </Button>
                      <TextBlock Text="{Binding CountLabel}"
                                 FontSize="16" FontWeight="Bold" Margin="8,0"
                                 VerticalAlignment="Center" MinWidth="50"
                                 TextAlignment="Center"/>
                      <Button Tag="{Binding}" Click="BtnPlusW_Click"
                              Style="{StaticResource BtnPrimary}" Padding="8,4">
                        <TextBlock Text="＋" FontSize="16" FontWeight="Bold"/>
                      </Button>
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock x:Name="TxtWeeklyEmpty"
                     Foreground="{StaticResource TextMuted}" FontSize="12"
                     Visibility="Collapsed"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
